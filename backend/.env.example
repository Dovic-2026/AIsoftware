# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=DOVIC AI Restaurant OS
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dovic_restaurant.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/dovic_db

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your restaurant WhatsApp number (where bot sends messages)
TWILIO_WHATSAPP_TO=whatsapp:+919876543210

# ── WhatsApp (Meta Cloud API) — alternative to Twilio ────────────────────────
META_WA_TOKEN=your_meta_whatsapp_token
META_WA_PHONE_ID=your_phone_number_id
META_WA_VERIFY_TOKEN=dovic_webhook_verify_2026

# ── AI (Optional — defaults to rule-based if not set) ────────────────────────
# Priority: Groq → OpenAI → Ollama → Rule-based (always works)

# Groq — FREE LLaMA 3 70B via cloud API (recommended for production)
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# OpenAI — paid fallback
OPENAI_API_KEY=sk-your-openai-key

# Ollama — LOCAL ONLY, leave blank in cloud deployment
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3:8b

# ── Redis (for Celery background tasks) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Reports ───────────────────────────────────────────────────────────────────
DAILY_REPORT_HOUR=6
DAILY_REPORT_MINUTE=0
REPORT_TIMEZONE=Asia/Kolkata

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
